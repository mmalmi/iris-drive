# Zapstore publication settings for scripts/local-release.mjs.
# Copy to .env.zapstore.local and fill locally. Do not commit secrets.

# zsp accepts SIGN_WITH directly. Use a release-only key.
SIGN_WITH=

# Alternative: point to a file containing an nsec. scripts/local-release.mjs
# reads it when SIGN_WITH is empty.
# NOSTR_KEY_PATH=/absolute/path/to/iris-drive-zapstore.nsec
