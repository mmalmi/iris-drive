#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROFILE="${IRIS_DRIVE_PROFILE:-debug}"

usage() {
  cat <<'EOF'
usage: ./tools/run-macos

Builds the Rust macOS menu-bar app plus the idrive daemon, then runs the
menu-bar app. The first launch creates ~/Iris Drive and starts syncing it.

Set IRIS_DRIVE_PROFILE=release to run a release build.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

cd "$ROOT"

build_args=()
profile_dir="debug"
if [[ "$PROFILE" == "release" ]]; then
  build_args+=(--release)
  profile_dir="release"
elif [[ "$PROFILE" != "debug" ]]; then
  echo "IRIS_DRIVE_PROFILE must be 'debug' or 'release'." >&2
  exit 2
fi

target_dir="$(
  cargo metadata --no-deps --format-version 1 |
    python3 -c 'import json, sys; print(json.load(sys.stdin)["target_directory"])'
)"

cargo build "${build_args[@]}" -p idrive -p iris-drive-mac

exec "$target_dir/$profile_dir/iris-drive-mac"
