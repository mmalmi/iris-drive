<Application x:Class="IrisDrive.WindowsShell.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <Color x:Key="IrisWindowColor">#F6F7F5</Color>
    <Color x:Key="IrisPanelColor">#FFFFFF</Color>
    <Color x:Key="IrisSidebarColor">#ECEFEB</Color>
    <Color x:Key="IrisTextColor">#202124</Color>
    <Color x:Key="IrisMutedColor">#68716D</Color>
    <Color x:Key="IrisBorderColor">#D7DDD8</Color>
    <Color x:Key="IrisAccentColor">#276EF1</Color>
    <Color x:Key="IrisSuccessColor">#1F8A5B</Color>

    <SolidColorBrush x:Key="IrisWindowBrush" Color="{StaticResource IrisWindowColor}" />
    <SolidColorBrush x:Key="IrisPanelBrush" Color="{StaticResource IrisPanelColor}" />
    <SolidColorBrush x:Key="IrisSidebarBrush" Color="{StaticResource IrisSidebarColor}" />
    <SolidColorBrush x:Key="IrisTextBrush" Color="{StaticResource IrisTextColor}" />
    <SolidColorBrush x:Key="IrisMutedBrush" Color="{StaticResource IrisMutedColor}" />
    <SolidColorBrush x:Key="IrisBorderBrush" Color="{StaticResource IrisBorderColor}" />
    <SolidColorBrush x:Key="IrisAccentBrush" Color="{StaticResource IrisAccentColor}" />
    <SolidColorBrush x:Key="IrisSuccessBrush" Color="{StaticResource IrisSuccessColor}" />

    <Style TargetType="{x:Type Window}">
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="Foreground" Value="{StaticResource IrisTextBrush}" />
      <Setter Property="Background" Value="{StaticResource IrisWindowBrush}" />
    </Style>

    <Style x:Key="IconGlyph" TargetType="{x:Type TextBlock}">
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style TargetType="{x:Type Button}">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="BorderBrush" Value="{StaticResource IrisBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="{StaticResource IrisPanelBrush}" />
      <Setter Property="Foreground" Value="{StaticResource IrisTextBrush}" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="{StaticResource IrisAccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource IrisAccentBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <Style x:Key="FlatButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="8,5" />
    </Style>

    <Style x:Key="IconButton" TargetType="{x:Type Button}" BasedOn="{StaticResource FlatButton}">
      <Setter Property="Width" Value="32" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="NavButton" TargetType="{x:Type Button}" BasedOn="{StaticResource FlatButton}">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0,2" />
      <Setter Property="Padding" Value="10,7" />
    </Style>

    <Style x:Key="FieldName" TargetType="{x:Type TextBlock}">
      <Setter Property="Foreground" Value="{StaticResource IrisMutedBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ValueText" TargetType="{x:Type TextBlock}">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="PanelBorder" TargetType="{x:Type Border}">
      <Setter Property="Background" Value="{StaticResource IrisPanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource IrisBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12" />
    </Style>
  </Application.Resources>
</Application>
