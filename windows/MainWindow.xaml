<Window x:Class="IrisDrive.WindowsShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Iris Drive"
        Width="960"
        Height="620"
        MinWidth="760"
        MinHeight="500"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
  <Grid>
    <Grid x:Name="SetupRoot" Visibility="Collapsed">
      <StackPanel Width="340" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="&#xE8B7;"
                   Style="{StaticResource IconGlyph}"
                   FontSize="78"
                   Foreground="{StaticResource IrisTextBrush}"
                   HorizontalAlignment="Center" />
        <TextBlock Text="Iris Drive"
                   FontSize="30"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,24" />

        <StackPanel x:Name="WelcomePanel">
          <Button Style="{StaticResource PrimaryButton}" Click="ShowCreate_Click" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock Text="&#xE710;" Style="{StaticResource IconGlyph}" Margin="0,0,8,0" />
              <TextBlock Text="Create profile" />
            </StackPanel>
          </Button>
          <Button Click="ShowRestore_Click" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock Text="&#xE72E;" Style="{StaticResource IconGlyph}" Margin="0,0,8,0" />
              <TextBlock Text="Restore profile" />
            </StackPanel>
          </Button>
          <Button Click="ShowLink_Click">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock Text="&#xE977;" Style="{StaticResource IconGlyph}" Margin="0,0,8,0" />
              <TextBlock Text="Link this device" />
            </StackPanel>
          </Button>
        </StackPanel>

        <StackPanel x:Name="CreatePanel" Visibility="Collapsed">
          <Button Style="{StaticResource IconButton}" Click="ShowWelcome_Click" HorizontalAlignment="Left">
            <TextBlock Text="&#xE72B;" Style="{StaticResource IconGlyph}" />
          </Button>
          <TextBlock Text="Create profile" FontSize="22" FontWeight="SemiBold" Margin="0,8,0,12" />
          <TextBlock Text="Device label" Style="{StaticResource FieldName}" Margin="0,0,0,4" />
          <TextBox x:Name="CreateLabelBox" MinHeight="34" Margin="0,0,0,12" />
          <Button x:Name="CreateSubmitButton" Style="{StaticResource PrimaryButton}" Click="CreateSubmit_Click">
            <TextBlock Text="Create profile" HorizontalAlignment="Center" />
          </Button>
        </StackPanel>

        <StackPanel x:Name="RestorePanel" Visibility="Collapsed">
          <Button Style="{StaticResource IconButton}" Click="ShowWelcome_Click" HorizontalAlignment="Left">
            <TextBlock Text="&#xE72B;" Style="{StaticResource IconGlyph}" />
          </Button>
          <TextBlock Text="Restore profile" FontSize="22" FontWeight="SemiBold" Margin="0,8,0,12" />
          <TextBlock Text="Secret key" Style="{StaticResource FieldName}" Margin="0,0,0,4" />
          <PasswordBox x:Name="RestoreSecretBox" MinHeight="34" Margin="0,0,0,10" />
          <TextBlock Text="Device label" Style="{StaticResource FieldName}" Margin="0,0,0,4" />
          <TextBox x:Name="RestoreLabelBox" MinHeight="34" Margin="0,0,0,12" />
          <Button x:Name="RestoreSubmitButton" Style="{StaticResource PrimaryButton}" Click="RestoreSubmit_Click">
            <TextBlock Text="Restore profile" HorizontalAlignment="Center" />
          </Button>
        </StackPanel>

        <StackPanel x:Name="LinkPanel" Visibility="Collapsed">
          <Button Style="{StaticResource IconButton}" Click="ShowWelcome_Click" HorizontalAlignment="Left">
            <TextBlock Text="&#xE72B;" Style="{StaticResource IconGlyph}" />
          </Button>
          <TextBlock Text="Link this device" FontSize="22" FontWeight="SemiBold" Margin="0,8,0,12" />
          <TextBlock Text="Owner public key" Style="{StaticResource FieldName}" Margin="0,0,0,4" />
          <TextBox x:Name="LinkOwnerBox" MinHeight="34" Margin="0,0,0,10" />
          <TextBlock Text="Device label" Style="{StaticResource FieldName}" Margin="0,0,0,4" />
          <TextBox x:Name="LinkLabelBox" MinHeight="34" Margin="0,0,0,12" />
          <Button x:Name="LinkSubmitButton" Style="{StaticResource PrimaryButton}" Click="LinkSubmit_Click">
            <TextBlock Text="Link device" HorizontalAlignment="Center" />
          </Button>
        </StackPanel>

        <StackPanel x:Name="AwaitingPanel" Visibility="Collapsed">
          <TextBlock Text="Awaiting approval" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12" />
          <TextBlock Text="Owner" Style="{StaticResource FieldName}" Margin="0,0,0,4" />
          <TextBox x:Name="AwaitingOwnerBox" IsReadOnly="True" MinHeight="34" Margin="0,0,0,10" />
          <TextBlock Text="This device" Style="{StaticResource FieldName}" Margin="0,0,0,4" />
          <TextBox x:Name="AwaitingDeviceBox" IsReadOnly="True" MinHeight="34" Margin="0,0,0,10" />
          <TextBlock Text="Request link" Style="{StaticResource FieldName}" Margin="0,0,0,4" />
          <TextBox x:Name="DeviceRequestBox"
                   IsReadOnly="True"
                   MinHeight="76"
                   TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto"
                   Margin="0,0,0,12" />
          <Button Style="{StaticResource PrimaryButton}" Click="CopyDeviceRequest_Click">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <TextBlock Text="&#xE8C8;" Style="{StaticResource IconGlyph}" Margin="0,0,7,0" />
              <TextBlock Text="Copy request" />
            </StackPanel>
          </Button>
        </StackPanel>

        <TextBlock x:Name="SetupNotice"
                   Foreground="{StaticResource IrisMutedBrush}"
                   TextWrapping="Wrap"
                   Margin="0,14,0,0" />
      </StackPanel>
    </Grid>

    <Grid x:Name="MainRoot" Visibility="Collapsed">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="160" />
        <ColumnDefinition Width="1" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Background="{StaticResource IrisSidebarBrush}">
        <StackPanel Margin="12,18">
          <Button x:Name="NavDriveButton" Tag="Drive" Style="{StaticResource NavButton}" Click="Nav_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8B7;" Style="{StaticResource IconGlyph}" Margin="0,0,8,0" />
              <TextBlock Text="My Drive" />
            </StackPanel>
          </Button>
          <Button x:Name="NavDevicesButton" Tag="Devices" Style="{StaticResource NavButton}" Click="Nav_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE716;" Style="{StaticResource IconGlyph}" Margin="0,0,8,0" />
              <TextBlock Text="Devices" />
            </StackPanel>
          </Button>
          <Button x:Name="NavBackupsButton" Tag="Backups" Style="{StaticResource NavButton}" Click="Nav_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8C7;" Style="{StaticResource IconGlyph}" Margin="0,0,8,0" />
              <TextBlock Text="Backups" />
            </StackPanel>
          </Button>
          <Button x:Name="NavNetworkButton" Tag="Network" Style="{StaticResource NavButton}" Click="Nav_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE968;" Style="{StaticResource IconGlyph}" Margin="0,0,8,0" />
              <TextBlock Text="Network" />
            </StackPanel>
          </Button>
          <Button x:Name="NavHashtreeButton" Tag="Hashtree" Style="{StaticResource NavButton}" Click="Nav_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE7B8;" Style="{StaticResource IconGlyph}" Margin="0,0,8,0" />
              <TextBlock Text="Hashtree" />
            </StackPanel>
          </Button>
          <Button x:Name="NavSettingsButton" Tag="Settings" Style="{StaticResource NavButton}" Click="Nav_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE713;" Style="{StaticResource IconGlyph}" Margin="0,0,8,0" />
              <TextBlock Text="Settings" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Background="{StaticResource IrisBorderBrush}" />

      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Margin="18,14,18,6" ItemHeight="34">
          <Button Click="OpenDrive_Click" Margin="0,0,8,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8B7;" Style="{StaticResource IconGlyph}" Margin="0,0,7,0" />
              <TextBlock Text="Drive" />
            </StackPanel>
          </Button>
          <Button x:Name="CopySnapshotButton" Click="CopySnapshot_Click" Margin="0,0,8,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8C8;" Style="{StaticResource IconGlyph}" Margin="0,0,7,0" />
              <TextBlock Text="Copy Snapshot" />
            </StackPanel>
          </Button>
          <Button x:Name="OpenSnapshotButton" Click="OpenSnapshot_Click" Margin="0,0,16,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE774;" Style="{StaticResource IconGlyph}" Margin="0,0,7,0" />
              <TextBlock Text="Open Snapshot" />
            </StackPanel>
          </Button>
          <Button Click="Restart_Click" Margin="0,0,8,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE72C;" Style="{StaticResource IconGlyph}" Margin="0,0,7,0" />
              <TextBlock Text="Restart" />
            </StackPanel>
          </Button>
          <Button x:Name="StopButton" Click="Stop_Click" Margin="0,0,8,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE71A;" Style="{StaticResource IconGlyph}" Margin="0,0,7,0" />
              <TextBlock Text="Stop" />
            </StackPanel>
          </Button>
          <Button x:Name="StartButton" Click="Start_Click" Margin="0,0,8,8">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE768;" Style="{StaticResource IconGlyph}" Margin="0,0,7,0" />
              <TextBlock Text="Start" />
            </StackPanel>
          </Button>
        </WrapPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="24,12,24,24">
            <Grid Margin="0,0,0,20">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="&#xE8B7;"
                         Style="{StaticResource IconGlyph}"
                         FontSize="38"
                         Margin="0,0,14,0"
                         Foreground="{StaticResource IrisTextBrush}" />
              <StackPanel Grid.Column="1">
                <TextBlock x:Name="DriveTitle" Text="My Drive" FontSize="23" FontWeight="SemiBold" />
                <TextBlock x:Name="DriveMessage" Text="Starting sync" Foreground="{StaticResource IrisMutedBrush}" />
              </StackPanel>
              <Border Grid.Column="2"
                      Background="{StaticResource IrisSuccessBrush}"
                      CornerRadius="12"
                      Padding="10,5"
                      VerticalAlignment="Top">
                <TextBlock x:Name="StatusPill" Text="Stopped" Foreground="White" FontWeight="SemiBold" />
              </Border>
            </Grid>

            <StackPanel x:Name="DrivePage">
              <UniformGrid Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource PanelBorder}" Margin="0,0,10,0">
                  <StackPanel>
                    <TextBlock Text="Files" Style="{StaticResource FieldName}" />
                    <TextBlock x:Name="FilesValue" Text="0" FontSize="23" FontWeight="Bold" />
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelBorder}" Margin="0,0,10,0">
                  <StackPanel>
                    <TextBlock Text="Blocks" Style="{StaticResource FieldName}" />
                    <TextBlock x:Name="BlocksValue" Text="0" FontSize="23" FontWeight="Bold" />
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelBorder}" Margin="0,0,10,0">
                  <StackPanel>
                    <TextBlock Text="Storage" Style="{StaticResource FieldName}" />
                    <TextBlock x:Name="StorageValue" Text="0 B" FontSize="23" FontWeight="Bold" />
                  </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelBorder}">
                  <StackPanel>
                    <TextBlock Text="Devices" Style="{StaticResource FieldName}" />
                    <TextBlock x:Name="DevicesValue" Text="0/0" FontSize="23" FontWeight="Bold" />
                  </StackPanel>
                </Border>
              </UniformGrid>
              <TextBlock x:Name="NoticeText"
                         Foreground="{StaticResource IrisMutedBrush}"
                         TextWrapping="Wrap"
                         Margin="0,0,0,12" />
              <ListBox x:Name="DrivesList" BorderBrush="{StaticResource IrisBorderBrush}" />
            </StackPanel>

            <StackPanel x:Name="DevicesPage" Visibility="Collapsed">
              <TextBlock Text="Devices" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,10" />
              <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,14">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="40" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Text="Owner" Style="{StaticResource FieldName}" />
                  <TextBlock x:Name="OwnerValue" Grid.Column="1" Style="{StaticResource ValueText}" />
                  <Button Grid.Column="2" Style="{StaticResource IconButton}" Click="CopyOwner_Click">
                    <TextBlock Text="&#xE8C8;" Style="{StaticResource IconGlyph}" />
                  </Button>
                  <TextBlock Grid.Row="1" Text="This device" Style="{StaticResource FieldName}" Margin="0,8,0,0" />
                  <TextBlock x:Name="DeviceValue" Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueText}" Margin="0,8,0,0" />
                  <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource IconButton}" Click="CopyDevice_Click" Margin="0,8,0,0">
                    <TextBlock Text="&#xE8C8;" Style="{StaticResource IconGlyph}" />
                  </Button>
                  <TextBlock Grid.Row="2" Text="State" Style="{StaticResource FieldName}" Margin="0,8,0,0" />
                  <TextBlock x:Name="AuthValue" Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueText}" Margin="0,8,0,0" />
                </Grid>
              </Border>

              <StackPanel x:Name="ApprovePanel" Margin="0,0,0,16">
                <TextBlock Text="Approve device" Style="{StaticResource FieldName}" Margin="0,0,0,6" />
                <DockPanel LastChildFill="True">
                  <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Click="ApproveDevice_Click" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="&#xE73E;" Style="{StaticResource IconGlyph}" Margin="0,0,7,0" />
                      <TextBlock Text="Approve" />
                    </StackPanel>
                  </Button>
                  <TextBox x:Name="ApproveLabelBox" DockPanel.Dock="Right" Width="150" MinHeight="34" Margin="8,0,0,0" />
                  <TextBox x:Name="ApproveDeviceBox" MinHeight="34" />
                </DockPanel>
              </StackPanel>

              <TextBlock Text="Authorized" Style="{StaticResource FieldName}" Margin="0,0,0,6" />
              <ListBox x:Name="PeersList" BorderBrush="{StaticResource IrisBorderBrush}" />
            </StackPanel>

            <StackPanel x:Name="BackupsPage" Visibility="Collapsed">
              <TextBlock Text="Backups" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,10" />
              <ListBox x:Name="BackupsList" BorderBrush="{StaticResource IrisBorderBrush}" Margin="0,0,0,14" />
              <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Click="SyncBackups_Click" Margin="8,0,0,0">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE895;" Style="{StaticResource IconGlyph}" Margin="0,0,7,0" />
                    <TextBlock Text="Sync" />
                  </StackPanel>
                </Button>
                <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Click="AddBackup_Click" Margin="8,0,0,0">
                  <TextBlock Text="&#xE710;" Style="{StaticResource IconGlyph}" />
                </Button>
                <TextBox x:Name="BackupLabelBox" DockPanel.Dock="Right" Width="150" MinHeight="34" Margin="8,0,0,0" />
                <TextBox x:Name="BackupTargetBox" MinHeight="34" />
              </DockPanel>
            </StackPanel>

            <StackPanel x:Name="NetworkPage" Visibility="Collapsed">
              <TextBlock Text="Network" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,12" />
              <TextBlock Text="FIPS" Style="{StaticResource FieldName}" Margin="0,0,0,6" />
              <ListBox x:Name="FipsList" BorderBrush="{StaticResource IrisBorderBrush}" Margin="0,0,0,14" />
              <TextBlock Text="Blossom" Style="{StaticResource FieldName}" Margin="0,0,0,6" />
              <ListBox x:Name="BlossomList" BorderBrush="{StaticResource IrisBorderBrush}" Margin="0,0,0,14" />
              <TextBlock Text="Relays" Style="{StaticResource FieldName}" Margin="0,0,0,6" />
              <ListBox x:Name="RelaysList" BorderBrush="{StaticResource IrisBorderBrush}" Margin="0,0,0,10" />
              <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Click="ResetRelays_Click" Margin="8,0,0,0">
                  <TextBlock Text="&#xE777;" Style="{StaticResource IconGlyph}" />
                </Button>
                <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Click="AddRelay_Click" Margin="8,0,0,0">
                  <TextBlock Text="&#xE710;" Style="{StaticResource IconGlyph}" />
                </Button>
                <TextBox x:Name="RelayBox" MinHeight="34" />
              </DockPanel>
            </StackPanel>

            <StackPanel x:Name="HashtreePage" Visibility="Collapsed">
              <TextBlock Text="Hashtree" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,12" />
              <Border Style="{StaticResource PanelBorder}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Text="Config" Style="{StaticResource FieldName}" />
                  <TextBlock x:Name="ConfigPathValue" Grid.Column="1" Style="{StaticResource ValueText}" />
                  <TextBlock Grid.Row="1" Text="Blocks" Style="{StaticResource FieldName}" Margin="0,8,0,0" />
                  <TextBlock x:Name="BlocksPathValue" Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueText}" Margin="0,8,0,0" />
                  <TextBlock Grid.Row="2" Text="Drive" Style="{StaticResource FieldName}" Margin="0,8,0,0" />
                  <TextBlock x:Name="DrivePathValue" Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueText}" Margin="0,8,0,0" />
                  <TextBlock Grid.Row="3" Text="Root" Style="{StaticResource FieldName}" Margin="0,8,0,0" />
                  <TextBlock x:Name="RootPathValue" Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueText}" Margin="0,8,0,0" />
                </Grid>
              </Border>
            </StackPanel>

            <StackPanel x:Name="SettingsPage" Visibility="Collapsed">
              <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="18" Margin="0,0,0,12" />
              <CheckBox x:Name="CloseToTrayCheckBox" Content="Tray on close" Checked="CloseToTray_Changed" Unchecked="CloseToTray_Changed" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</Window>
