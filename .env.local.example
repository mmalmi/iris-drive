# Local developer-machine settings. Copy to .env.local and edit locally.
# .env.local is gitignored and auto-loaded by scripts/macos-dev-app.sh.

# Needed for Finder's File Provider / Locations integration during local runs.
# Use a team that can provision to.iris.drive.macos and its File Provider extension.
IRIS_DRIVE_MACOS_SIGNING=development
IRIS_DRIVE_DEVELOPMENT_TEAM=

# Optional. Defaults to "Apple Development".
# IRIS_DRIVE_CODESIGN_IDENTITY=Apple Development

# Optional. Leave enabled so Xcode can create/update local development profiles.
# IRIS_DRIVE_ALLOW_PROVISIONING_UPDATES=1

# Optional. Use these when Xcode has no signed-in account but you have an App
# Store Connect API key with certificate/profile management rights.
# IRIS_DRIVE_ASC_AUTH_KEY_PATH=/Users/you/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
# IRIS_DRIVE_ASC_AUTH_KEY_ID=XXXXXXXXXX
# IRIS_DRIVE_ASC_AUTH_KEY_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Optional isolated app data override. Leave unset for real File Provider runs.
# IRIS_DRIVE_APP_BASE_DIR=

# Optional VM deploy defaults for scripts/dev-vm-update-run.sh. The script can
# also derive these from same-named local git remotes when present.
# IRIS_DRIVE_DEV_VM_MACOS_REMOTE=macos-utm
# IRIS_DRIVE_DEV_VM_UBUNTU_REMOTE=ubuntu-dev
# IRIS_DRIVE_DEV_VM_WINDOWS_REMOTE=win11-dev
# IRIS_DRIVE_DEV_VM_FIPS_PORT=22121
