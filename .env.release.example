# Optional overrides for scripts/local-release.mjs.
# Copy to .env.release.local and edit locally when machine-specific paths or
# signing inputs are needed. Do not commit .env.release.local.

# htree release tree name used by idrive update.
IRIS_DRIVE_RELEASE_TREE=releases/iris-drive
# Public resolver bases to refresh and verify after final htree publish.
# Use "none" to skip this post-publish latest check.
# IRIS_DRIVE_RELEASE_RESOLVER_REFRESH_BASE_URLS=https://cdn.iris.to

# Release gate knobs.
# IRIS_DRIVE_RELEASE_GATE_FULL=1
# IRIS_DRIVE_RELEASE_GATE_ANDROID=1
# IRIS_DRIVE_RELEASE_GATE_IOS=1
# IRIS_DRIVE_RELEASE_GATE_MACOS=1

# Release build knobs.
# IRIS_DRIVE_IOS_ARCHIVE_PATH=/absolute/path/to/IrisDriveIOS.xcarchive
# IRIS_DRIVE_IOS_DIST_DIR=/absolute/path/to/ios-release-dist
# IRIS_DRIVE_IOS_TEAM_ID=8G9P8AN75D
# Extension bundle IDs default to <bundle>.FileProvider and
# <bundle>.ShareExtension; the app group defaults to group.<bundle>.
# IRIS_DRIVE_IOS_BUNDLE_ID=fi.siriusbusiness.drive
# IRIS_DRIVE_IOS_PROFILES_ENV_PATH=/absolute/path/to/provisioning.env
# IRIS_DRIVE_IOS_PROFILE_RECREATE=true
# IRIS_DRIVE_IOS_PROFILE_NAME_SUFFIX=2026-06-02
# IRIS_DRIVE_IOS_SIGNING_STYLE=automatic
# IRIS_DRIVE_IOS_TESTFLIGHT_CHANNELS=internal,public
# IRIS_DRIVE_IOS_PUBLIC_TESTFLIGHT=1
# IRIS_DRIVE_IOS_INTERNAL_ONLY=false
# IRIS_DRIVE_IOS_AFTER_UPLOAD_COMMAND=/absolute/path/to/private-post-upload-helper
# IRIS_DRIVE_IOS_SKIP_TESTFLIGHT_PUBLISH=1
# IRIS_DRIVE_MACOS_SIGN_IDENTITY=Developer ID Application: Example (TEAMID)
# IRIS_DRIVE_MACOS_CODESIGN_ATTEMPTS=8
# IRIS_DRIVE_MACOS_CODESIGN_RETRY_DELAY_SECONDS=30
# For full macOS FileProvider releases, create/download Developer ID profiles:
# scripts/macos-profiles ensure
# This writes dist/macos/provisioning.env, which local-release auto-loads.
# Developer ID releases keep Team-ID app groups for FileProvider, but strip
# Associated Domains unless the embedded profile launch-authorizes the exact
# requested entitlement values.
# IRIS_DRIVE_MACOS_KEEP_PROVISIONED_ENTITLEMENTS=false
# IRIS_DRIVE_MACOS_PROFILE_TYPE=MAC_APP_DIRECT
# IRIS_DRIVE_MACOS_PROFILES_ENV_PATH=dist/macos/provisioning.env
# IRIS_DRIVE_MACOS_APP_PROVISIONING_PROFILE=/absolute/path/to/app.provisionprofile
# IRIS_DRIVE_MACOS_FILEPROVIDER_PROVISIONING_PROFILE=/absolute/path/to/fileprovider.provisionprofile
# Preferred: create a local notarytool profile with:
# xcrun notarytool store-credentials iris-drive-notary --key /path/AuthKey_KEYID.p8 --key-id KEYID --issuer ISSUER_ID
# IRIS_DRIVE_MACOS_NOTARY_KEYCHAIN_PROFILE=iris-drive-notary
# Or pass App Store Connect API-key auth directly. These default to the
# matching IRIS_DRIVE_ASC_* values when unset.
# IRIS_DRIVE_MACOS_NOTARY_KEY_PATH=/absolute/path/to/AuthKey_KEYID.p8
# IRIS_DRIVE_MACOS_NOTARY_KEY_ID=
# IRIS_DRIVE_MACOS_NOTARY_ISSUER_ID=

# Android signing inputs for public APK builds, if the Gradle release build is
# extended to consume local signing config on this host.
# ANDROID_KEYSTORE_PATH=/absolute/path/to/upload-keystore.jks
# ANDROID_KEYSTORE_PASSWORD=change-me
# ANDROID_KEY_ALIAS=iris-drive-upload
# ANDROID_KEY_PASSWORD=change-me

# Apple signing/notarization/App Store Connect inputs are intentionally local.
# Keep certificates, API keys, and passwords outside git.
# IRIS_DRIVE_ASC_KEY_ID=
# IRIS_DRIVE_ASC_ISSUER_ID=
# IRIS_DRIVE_ASC_KEY_PATH=/absolute/path/to/AuthKey_KEYID.p8
# IRIS_DRIVE_ASC_CERTIFICATE_ID=

# TestFlight group and public beta metadata. Existing App Store Connect values
# are reused when present; these are required only when the script needs to
# create or update public beta metadata.
# IRIS_DRIVE_TESTFLIGHT_GROUPS=Internal Testers
# IRIS_DRIVE_TESTFLIGHT_PUBLIC_GROUPS=Public Beta
# IRIS_DRIVE_TESTFLIGHT_PRIVACY_POLICY_URL=https://irisdrive.iris.to/privacy
# IRIS_DRIVE_TESTFLIGHT_FEEDBACK_EMAIL=ios-feedback@example.com
# IRIS_DRIVE_TESTFLIGHT_CONTACT_FIRST_NAME=Iris
# IRIS_DRIVE_TESTFLIGHT_CONTACT_LAST_NAME=Drive
# IRIS_DRIVE_TESTFLIGHT_CONTACT_PHONE=+15555555555
# IRIS_DRIVE_TESTFLIGHT_CONTACT_EMAIL=ios-review@example.com
